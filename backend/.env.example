# PostgreSQL (see repo root docker-compose.yml)
DATABASE_URL=postgresql://fieldwise:fieldwise@localhost:5432/fieldwise

JWT_SECRET=change-me-in-development-min-32-chars

# Optional: advisory list cache + weather cache
REDIS_URL=redis://localhost:6379

# CORS origin(s) for the Vite dev server. Use commas if you need several (5173 vs 5174, localhost vs 127.0.0.1).
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

PORT=4000

# Uploaded files root (created automatically)
UPLOAD_DIR=./uploads

# Advisory catalog cache TTL (seconds)
REDIS_ADVISORY_CACHE_TTL_SEC=60

# Weather response cache TTL (seconds)
WEATHER_CACHE_TTL_SEC=900

# Optional: seed one admin user on API startup if both are set (skipped when user exists).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=choose-a-strong-password
